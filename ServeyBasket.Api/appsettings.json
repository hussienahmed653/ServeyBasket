{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;DataBase= ServeyBasket;Integrated Security=True;Encrypt=False;Trust Server Certificate=True;",
    "HangfireConnection": "Data Source=.;DataBase= ServeyBasketJobs;Integrated Security=True;Encrypt=False;Trust Server Certificate=True;"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "Path": "E:\\Logs\\log-.txt",
          "RollingInterval": "Day",
          "Formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact"
          //"OutputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {SourceContext} - {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "ServeyBasket"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "", // in secrets.json file
    "Issuer": "ServeyBasket",
    "Audience": "ServeyBasket users",
    "ExpireMinutes": 30
  },
  "MailSettings": {
    "Mail": "tamara.hahn@ethereal.email",
    "Password": "", // in secrets.json file"
    "DisplayName": "ServeyBasket",
    "Host": "smtp.ethereal.email",
    "Port": 587
  },
  "HangfireSettings": {
    "UserName": "", // in secrets.json file"
    "Password": "" // in secrets.json file"
  }
}
